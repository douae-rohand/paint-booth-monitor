# PostgreSQL (conteneur Docker)
POSTGRES_DB=supervision_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me

# Comptes applicatifs
JAVA_SERVICE_DB_USER=java_service
JAVA_SERVICE_DB_PASSWORD=change_me
PYTHON_SERVICE_DB_USER=python_service
PYTHON_SERVICE_DB_PASSWORD=change_me

# Java service
JWT_SECRET=change_me_to_a_long_random_secret_key
JWT_EXPIRATION=86400000
SPRING_JPA_SHOW_SQL=false

# Python service
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
PLC_IP=192.168.0.1
PLC_RACK=0
PLC_SLOT=1

# Frontend (arguments de build Docker)
VITE_API_URL=http://localhost:8081
VITE_WS_URL=ws://localhost:8081/ws
