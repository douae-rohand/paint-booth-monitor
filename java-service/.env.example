# PostgreSQL (dev local — mêmes valeurs que le .env racine / Docker)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/supervision_db
SPRING_DATASOURCE_USERNAME=java_service
SPRING_DATASOURCE_PASSWORD=change_me

# Service Python interne
PYTHON_SERVICE_URL=http://localhost:8000

# JWT — clé secrète longue (min. 32 caractères)
JWT_SECRET=change_me_to_a_long_random_secret_key
JWT_EXPIRATION=86400000

# Admin initial (à modifier impérativement en production !)
ADMIN_INITIAL_EMAIL=admin@renault.com
ADMIN_INITIAL_PASSWORD=ChangeMe123!

# JPA (optionnel)
SPRING_JPA_SHOW_SQL=true
